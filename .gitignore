# ================================================
#  .gitignore — Team23 App
# ================================================

# Cache Python
__pycache__/
*.pyc

# Folder hasil dekripsi / file yang diterima (berubah-ubah)
diterima/
diterima_chat/

# Paket terenkripsi hasil demo (jangan diupload)
*.team23

# File pribadi/sensitif
*.pdf

# Catatan:
# Folder kunci/ dan sertifikat/ SENGAJA ikut di-commit supaya teman yang
# 'git clone' langsung bisa menjalankan chat mTLS tanpa setup manual.
# Ini hanya kunci & CA "buangan" untuk demo kelas — bukan kunci asli.
